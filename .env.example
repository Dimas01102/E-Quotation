APP_NAME="RFQ System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rfq_system
DB_USERNAME=root
DB_PASSWORD=

# Session via cookie (penting untuk AJAX + Sanctum)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000,::1

# Mail - gunakan SMTP Gmail atau Mailtrap
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD="your_app_password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@rfqsystem.com
MAIL_FROM_NAME="RFQ System"

# Untuk testing gunakan Mailtrap:
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_mailtrap_user
# MAIL_PASSWORD=your_mailtrap_pass

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database
BROADCAST_CONNECTION=log

VITE_APP_NAME="${APP_NAME}"
